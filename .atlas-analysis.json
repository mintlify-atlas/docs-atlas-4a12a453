  "keyFeatures": [
    "Stateless face recognition with zero persistence",
    "Sub-100ms inference using YuNet and SFace ONNX models",
    "Built-in rate limiting (5 req/sec per IP)",
    "CORS-enabled REST API for hospital IT systems",
    "Base64 and URL image input support",
    "Real-time similarity scoring with configurable thresholds",
    "Request statistics and health monitoring"
  ],
  "publicApiSurface": [
    "POST /compare - Compare target face against database",
    "GET /stats - Retrieve API usage statistics",
    "GET /health - Health check endpoint",
    "CompareRequest - Request payload structure",
    "CompareResponse - Response with match results",
    "Person - Database person structure",
    "MatchResult - Individual match result with probability"
  ]
